# VK Teams Bot API
VK_TEAMS_BOT_TOKEN=
VK_TEAMS_API_URL=

# Источник презентаций: по умолчанию папка presentations/ в репозитории (файлы кладутся через git).
# Раскомментировать и указать свой путь, только если нужна папка вне репозитория.
# PRESENTATIONS_FOLDER_PATH=/absolute/path/to/presentations

# Catalog storage (JSON или SQLite, см. §5.1.9 ТЗ)
CATALOG_STORAGE_PATH=storage/catalog/catalog.sqlite

# Python-подпроцессы (SlideTextExtractor, SlideCloner)
PYTHON_BIN=python

# Лимиты сборки
MAX_SLIDES_PER_DECK=10
