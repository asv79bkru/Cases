# VK Teams Bot API
VK_TEAMS_BOT_TOKEN=
VK_TEAMS_API_URL=

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_PATH=config/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# Catalog storage (JSON или SQLite, см. §5.1.9 ТЗ)
CATALOG_STORAGE_PATH=storage/catalog/catalog.sqlite

# Python-подпроцессы (SlideTextExtractor, SlideCloner)
PYTHON_BIN=python

# Лимиты сборки
MAX_SLIDES_PER_DECK=10
