# VK Teams Bot API
VK_TEAMS_BOT_TOKEN=
VK_TEAMS_API_URL=

# Источник презентаций: по умолчанию папка presentations/ рядом с приложением (не в git, заливается при деплое).
# Раскомментировать и указать свой путь, только если нужна папка в другом месте.
# PRESENTATIONS_FOLDER_PATH=/absolute/path/to/presentations

# Catalog storage (JSON или SQLite, см. §5.1.9 ТЗ)
CATALOG_STORAGE_PATH=storage/catalog/catalog.sqlite

# Python-подпроцессы (SlideTextExtractor, SlideCloner)
PYTHON_BIN=python

# Лимиты сборки
MAX_SLIDES_PER_DECK=10

# LLM для дополнения тегов кейсов (см. src/Api/Providers). provider: ollama | opencodezen
AI_PROVIDER=opencodezen
OLLAMA_API_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=
OPENCODEZEN_API_KEY=
OPENCODEZEN_MODEL=
